# Cloudflare Tunnel token (from Zero Trust dashboard -> Networks -> Tunnels)
CLOUDFLARE_TUNNEL_TOKEN=eyJhIjoixxxxxxxxx

# Obsidian Sync credentials (single account, Sync Plus plan)
OBSIDIAN_EMAIL=you@example.com
OBSIDIAN_PASSWORD=
ENCRYPTION_PASSWORD=                 # optional — only if E2EE is enabled on the vaults

# Vault names as they appear in Obsidian Sync (case-sensitive)
AUDREY_VAULT_NAME=audrey-vault
TAYLOR_VAULT_NAME=taylor-vault

# Auth proxy — OAuth 2.1 client credentials (one pair per vault)
# Generate with: uuidgen (client ID) and openssl rand -hex 32 (client secret)
AUDREY_CLIENT_ID=
AUDREY_CLIENT_SECRET=
TAYLOR_CLIENT_ID=
TAYLOR_CLIENT_SECRET=

# Auth proxy — secret used for internal integrity checks (random 64-char hex)
AUTH_SECRET=

# Auth proxy — public-facing base URLs (must match Cloudflare tunnel hostnames)
AUDREY_PUBLIC_URL=https://audrey-vault.yourdomain.com
TAYLOR_PUBLIC_URL=https://taylor-vault.yourdomain.com
