# =============================================================================
# .gitignore — ZIA Ansible Automation Framework
# =============================================================================
# PURPOSE:
#   Prevents sensitive files, temporary artifacts, and environment-specific
#   files from being committed to version control.
#
# SECURITY CRITICAL:
#   The following must NEVER be committed:
#   - Vault password files
#   - Any file containing credentials
#   - API keys or tokens
#   - Private keys or certificates
#
# ENTERPRISE NOTE:
#   In a GitOps workflow, this repository should be treated as:
#   - Infrastructure as Code (IaC) — commit all configuration
#   - Secrets-free — all secrets live in HashiCorp Vault
#   - Audit-ready — every change is a git commit with author/timestamp
# =============================================================================

# ---------------------------------------------------------------------------
# SECURITY — NEVER COMMIT THESE
# ---------------------------------------------------------------------------
# Ansible Vault password file (contains the key to decrypt vault files)
.vault_pass
.vault_password
vault_pass.txt
vault_password.txt

# Any file that might contain credentials
*credentials*
*secrets*
*password*
*passwd*
*.key
*.pem
*.p12
*.pfx

# Environment files with secrets
.env
.env.local
.env.production
.env.staging

# HashiCorp Vault token files
.vault-token
vault-token.txt

# ---------------------------------------------------------------------------
# ANSIBLE ARTIFACTS
# ---------------------------------------------------------------------------
# Retry files created when playbooks fail
*.retry
.retry/

# Fact cache (contains gathered facts, may include sensitive data)
/tmp/ansible_fact_cache/
fact_cache/

# Ansible temporary files
.ansible/
~/.ansible/tmp/

# ---------------------------------------------------------------------------
# PYTHON
# ---------------------------------------------------------------------------
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
env/
.venv/
.env/
ENV/
env.bak/
venv.bak/

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
*.manifest
*.spec

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# ---------------------------------------------------------------------------
# MOLECULE TESTING
# ---------------------------------------------------------------------------
# Molecule ephemeral directory (created during test runs)
molecule/*/molecule_state.yml
molecule/*/.molecule/
.molecule/

# ---------------------------------------------------------------------------
# EDITOR & IDE FILES
# ---------------------------------------------------------------------------
# Visual Studio Code
.vscode/
*.code-workspace

# JetBrains IDEs (PyCharm, IntelliJ)
.idea/
*.iml
*.iws
*.ipr

# Vim
*.swp
*.swo
*~
.netrwhist

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msm
*.msp
*.lnk

# Linux
*~

# ---------------------------------------------------------------------------
# LOGS
# ---------------------------------------------------------------------------
# Log files (logs should be shipped to SIEM, not stored in git)
*.log
logs/
/var/log/ansible/

# ---------------------------------------------------------------------------
# GENERATED DOCUMENTATION
# ---------------------------------------------------------------------------
# Auto-generated docs (regenerated by 'make docs')
docs/generated/

# ---------------------------------------------------------------------------
# COLLECTIONS (installed locally)
# ---------------------------------------------------------------------------
# If collections are installed locally (not system-wide), exclude them
# They should be installed via: ansible-galaxy collection install -r requirements.yml
collections/

# ---------------------------------------------------------------------------
# TEMPORARY FILES
# ---------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.bak
*.backup
*.orig

# ---------------------------------------------------------------------------
# WHAT SHOULD BE COMMITTED
# ---------------------------------------------------------------------------
# ✅ All YAML playbooks and roles
# ✅ All vars files (WITHOUT secrets — use Vault for secrets)
# ✅ Inventory files (hosts, group_vars with non-sensitive data)
# ✅ requirements.yml
# ✅ ansible.cfg
# ✅ Makefile
# ✅ Documentation (docs/)
# ✅ Molecule test files
# ✅ Custom modules (library/)
# ✅ Filter plugins (filter_plugins/)
# ✅ .gitignore (this file)
